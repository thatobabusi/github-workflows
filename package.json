{
  "name": "github-workflows",
  "version": "2.1.1",
  "description": "Unified standards, workflow templates, and interactive reference for all thatobabusi projects",
  "scripts": {
    "lint": "npm run lint:html && npm run lint:css && npm run lint:js && npm run lint:links",
    "lint:links": "node scripts/check-links.mjs",
    "lint:html": "htmlhint index.html",
    "lint:css": "stylelint assets/**/*.css",
    "lint:js": "eslint assets/scripts.js",
    "test:e2e": "playwright test",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "dev": "python -m http.server 8090"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "eslint": "^8.57.0",
    "htmlhint": "^1.1.4",
    "stylelint": "^15.11.0",
    "stylelint-config-standard": "^34.0.0"
  },
  "keywords": [
    "standards",
    "workflows",
    "ci-cd",
    "github-actions",
    "templates"
  ],
  "author": "Thato Babusi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thatobabusi/github-workflows.git"
  }
}
