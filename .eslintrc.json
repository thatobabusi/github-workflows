{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "script"
  },
  "globals": {
    "hljs": "readonly"
  },
  "rules": {
    "no-console": "off",
    "no-debugger": "warn",
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_", "caughtErrorsIgnorePattern": "^_" }],
    "indent": ["warn", 4],
    "quotes": ["warn", "single"],
    "semi": ["warn", "always"],
    "eqeqeq": ["warn", "always"],
    "curly": ["warn", "all"]
  }
}
